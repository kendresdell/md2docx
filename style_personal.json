{
  "_comment": "md_to_docx style guide — Ken's personal guide. Black cover, dark hacker vibe.",

  "document": {
    "page_size": "letter",
    "line_spacing": 1.15,
    "margins": {
      "top_cm": 2.0, "bottom_cm": 2.0,
      "left_cm": 2.5, "right_cm": 2.5
    }
  },

  "fonts": {
    "body":         "Poppins",
    "h1_override":  "Roboto Slab",
    "cover_title":  "Poppins",
    "footer":       "Poppins"
  },

  "headings": {
    "h1": { "size": 24, "color": "#1A1A2E", "bold": false, "italic": false },
    "h2": { "size": 18, "color": "#16213E", "bold": false, "italic": false },
    "h3": { "size": 14, "color": "#E94560", "bold": false, "italic": false },
    "h4": { "size": 12, "color": "#E94560", "bold": false, "italic": false }
  },

  "body":        { "size": 11, "color": "#434343" },
  "blockquote":  { "size": 10, "color": "#555555", "italic": false, "border_color": "#E94560", "bg_color": "#FFF5F7", "border_width": 24, "border_space": 10, "space_before": 8, "space_after": 8 },
  "code_inline": { "size": 10, "color": "#434343" },
  "code_block":  { "size": 10, "color": "#555555" },

  "table": {
    "header_bg":   "#1A1A2E",
    "header_text": "#FFFFFF",
    "body_text":   "#434343",
    "header_size": 10,
    "body_size":   10
  },

  "cover": {
    "enabled":       true,
    "bg_color":      "#000000",
    "logo_path":     "no-logo.png",
    "logo_width_cm": 0,
    "title":         "OpenCode — Personal Setup Guide",
    "title_size":    48,
    "title_color":   "#FFFFFF",
    "top_spacer_pt": 72
  },

  "footer": {
    "label": "Ken's personal recipe — for family and weekend projects",
    "size":  9,
    "color": "#1A1A1A"
  }
}
